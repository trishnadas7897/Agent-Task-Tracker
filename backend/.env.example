# MongoDB Atlas connection string (see Doc 2 §1). Include the DB name in the path.
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/kpi_agent?retryWrites=true&w=majority

# Auth
JWT_SECRET=replace-with-a-64-char-random-hex
JWT_EXP_DAYS=1

# Gemini (free tier, 2.5 Flash). See Doc 2 §2.
GEMINI_API_KEY=replace-with-google-ai-studio-key
GEMINI_MODEL_NAME=gemini-2.5-flash
GEMINI_API_ENDPOINT=https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash:generateContent

# Comma-separated list of allowed frontend origins (no trailing slash)
CORS_ORIGINS=http://localhost:5173,http://localhost:8081
